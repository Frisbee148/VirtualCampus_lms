# --- Server ---
PORT=4000
NODE_ENV=development
# CORS origin for the Vite client
CLIENT_ORIGIN=http://localhost:5173

# --- PostgreSQL ---
# Either set DATABASE_URL (takes priority) ...
DATABASE_URL=postgres://postgres:postgres@localhost:5432/virtualcampus
# ... or the discrete parts (used when DATABASE_URL is empty):
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=virtualcampus
# Set true for managed PG (Render/Supabase/Neon) that require SSL
PGSSL=false

# --- Auth ---
# CHANGE THIS in production. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Demo login ---
# Single shared credential. Works for EVERY role (role picked in the dropdown).
# These are the ONLY credentials that can log in. Change then re-run db:seed.
DEMO_USERNAME=demo
DEMO_PASSWORD=demo123
